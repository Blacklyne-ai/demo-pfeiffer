---
// Ehrliche Trust-Leiste. Zeigt ECHTE Google-Sterne nur, wenn ein verifiziertes
// Rating vorliegt (site.google.rating > 0). Solange keine Bewertungen existieren
// (aktuell 0), werden die belegbaren Vertrauens-Säulen + ein Link zum echten
// Google-Eintrag gezeigt — keine erfundenen Sterne (HWG/Fairness, NIE faken).
import Icon from './Icon.astro';
import { site } from '../data/site';

const pillars = [
  { icon: 'BadgeCheck', title: 'Heilpraktikerin für Physiotherapie', note: 'Behandlung auch ohne ärztliche Verordnung — geprüft 2015.' },
  { icon: 'Award', title: 'Lizenzierte Praxis · PhysioNetzwerk', note: 'Rückentriathlon gegen Rückenschmerzen.' },
  { icon: 'Heart', title: 'Persönlich geführt', note: 'Silke Pfeiffer-Flößer und ein eingespieltes Team.' },
];

const hasRating = typeof site.google.rating === 'number' && (site.google.rating as number) > 0;
const full = hasRating ? Math.round(site.google.rating as number) : 0;
---
<section class="bg-paper border-b border-line">
  <div class="container-px py-10 md:py-12">
    <div class="grid lg:grid-cols-[1fr,auto] gap-8 lg:gap-12 items-center">
      <!-- Vertrauens-Säulen -->
      <ul class="grid sm:grid-cols-3 gap-5 md:gap-7">
        {pillars.map((p) => (
          <li class="flex items-start gap-3.5">
            <span class="icon-chip flex-shrink-0"><Icon name={p.icon} size={21} strokeWidth={1.8} /></span>
            <span>
              <span class="block text-ink font-medium leading-snug text-[0.97rem]">{p.title}</span>
              <span class="block text-muted text-[0.86rem] leading-snug mt-0.5">{p.note}</span>
            </span>
          </li>
        ))}
      </ul>

      <!-- Google-Chip: echte Sterne nur bei verifiziertem Rating -->
      <a href={site.google.placeUrl} target="_blank" rel="noopener"
        class="group inline-flex items-center gap-3.5 rounded-2xl border border-line bg-white px-5 py-3.5 shadow-soft hover:shadow-lift transition lg:justify-self-end">
        <svg width="22" height="22" viewBox="0 0 24 24" aria-hidden="true" class="flex-shrink-0">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.27-4.74 3.27-8.1Z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A11 11 0 0 0 12 23Z"/>
          <path fill="#FBBC05" d="M5.84 14.1a6.6 6.6 0 0 1 0-4.2V7.06H2.18a11 11 0 0 0 0 9.88l3.66-2.84Z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1A11 11 0 0 0 2.18 7.06l3.66 2.84C6.71 7.3 9.14 5.38 12 5.38Z"/>
        </svg>
        <span class="text-left">
          {hasRating ? (
            <>
              <span class="flex items-center gap-1.5">
                <span class="font-display text-ink text-lg leading-none">{(site.google.rating as number).toLocaleString('de-DE')}</span>
                <span class="flex">
                  {[0,1,2,3,4].map((i) => (
                    <svg width="14" height="14" viewBox="0 0 24 24" fill={i < full ? '#F4B400' : '#E7DCCD'}><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  ))}
                </span>
              </span>
              <span class="block text-muted text-[0.8rem] mt-0.5">{site.google.reviews} Google-Rezensionen</span>
            </>
          ) : (
            <>
              <span class="block text-ink font-medium text-[0.95rem] leading-snug">Praxis auf Google ansehen</span>
              <span class="block text-muted text-[0.8rem] mt-0.5 inline-flex items-center gap-1">Standort &amp; Route <Icon name="ArrowUpRight" size={12} strokeWidth={2.2} class="group-hover:translate-x-0.5 transition-transform" /></span>
            </>
          )}
        </span>
      </a>
    </div>
  </div>
</section>
