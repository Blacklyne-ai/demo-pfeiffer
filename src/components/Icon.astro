---
// Zentrale Lucide-Icon-Map (@lucide/astro, named imports).
// Data-Files referenzieren Icons per Name. Namen gegen node_modules geprüft.
// Brand-Icons (Facebook/Instagram/LinkedIn) gibt es in Lucide NICHT → inline SVG (Footer).
import {
  Brain, Bone, Stethoscope, Baby, Activity, Medal, ShieldCheck, HeartPulse,
  Dumbbell, Footprints, Sparkles, Leaf, Users, HandHeart, Waypoints, Route,
  Target, Lightbulb, Spline, Accessibility, Move, MoveRight, StretchHorizontal, ScanHeart,
  Phone, PhoneCall, Mail, MapPin, MapPinned, Map, Navigation, Clock, CalendarCheck, CalendarDays, Send,
  ArrowRight, ArrowUpRight, ArrowLeft, ChevronDown, ChevronRight, ChevronUp,
  Menu, X, Check, CircleCheckBig, ListChecks, Plus, Minus, Quote, MessageCircle,
  Star, Info, CircleDot, ExternalLink, Hand,
  Car, BadgeEuro, PiggyBank, Building2, HeartHandshake, GraduationCap, BriefcaseBusiness, Handshake,
  Droplets, Zap, PersonStanding, Bandage, Gauge, Flame, Gift, BadgeCheck, Heart, Wind,
} from '@lucide/astro';

const MAP: Record<string, any> = {
  Brain, Bone, Stethoscope, Baby, Activity, Medal, ShieldCheck, HeartPulse,
  Dumbbell, Footprints, Sparkles, Leaf, Users, HandHeart, Waypoints, Route,
  Target, Lightbulb, Spline, Accessibility, Move, MoveRight, StretchHorizontal, ScanHeart,
  Phone, PhoneCall, Mail, MapPin, MapPinned, Map, Navigation, Clock, CalendarCheck, CalendarDays, Send,
  ArrowRight, ArrowUpRight, ArrowLeft, ChevronDown, ChevronRight, ChevronUp,
  Menu, X, Check, CircleCheckBig, ListChecks, Plus, Minus, Quote, MessageCircle,
  Star, Info, CircleDot, ExternalLink, Hand,
  Car, BadgeEuro, PiggyBank, Building2, HeartHandshake, GraduationCap, BriefcaseBusiness, Handshake,
  Droplets, Zap, PersonStanding, Bandage, Gauge, Flame, Gift, BadgeCheck, Heart, Wind,
};

interface Props { name: string; size?: number; class?: string; strokeWidth?: number }
const { name, size = 24, class: className = '', strokeWidth = 1.75 } = Astro.props;
const Cmp = MAP[name] ?? CircleDot;
---
<Cmp size={size} class={className} stroke-width={strokeWidth} />
