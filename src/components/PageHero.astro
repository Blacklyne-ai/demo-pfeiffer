---
// Subpage-Hero - ruhig, warm (Paper), type-led. Breadcrumb + Eyebrow + H1 + Intro.
// Optionales Foto im weichen Frame. Keine Watermarks/Caustics.
import Icon from './Icon.astro';
interface Props {
  eyebrow?: string;
  title: string;        // darf <em>…</em> enthalten
  subtitle?: string;
  crumb?: string;
  image?: string;
  imageAlt?: string;
  primary?: { href: string; label: string };
  secondary?: { href: string; label: string };
}
const { eyebrow, title, subtitle, crumb, image, imageAlt = '', primary, secondary } = Astro.props;
---
<section class="bg-cream relative overflow-hidden pt-28 pb-14 md:pt-36 md:pb-20 border-b border-line">
  <div class="container-px relative">
    <nav class="flex items-center gap-2 text-[0.8rem] text-muted mb-7" aria-label="Breadcrumb">
      <a href="/" class="hover:text-crimson-ink transition">Start</a>
      <Icon name="ChevronRight" size={13} strokeWidth={2.2} />
      <span class="text-ink/70 font-medium">{crumb ?? 'Seite'}</span>
    </nav>
    <div class={`grid ${image ? 'lg:grid-cols-12 gap-10 lg:gap-16 items-center' : ''}`}>
      <div class={image ? 'lg:col-span-7' : 'max-w-3xl'}>
        {eyebrow && <span class="eyebrow mb-5">{eyebrow}</span>}
        <h1 class="display-2 text-balance" set:html={title} />
        {subtitle && <p class="lead mt-6 max-w-2xl text-pretty">{subtitle}</p>}
        {(primary || secondary) && (
          <div class="flex flex-col sm:flex-row gap-3 mt-9">
            {primary && <a href={primary.href} class="btn btn-crimson btn-lg">{primary.label}<Icon name="ArrowRight" size={16} strokeWidth={2.2} /></a>}
            {secondary && <a href={secondary.href} class="btn btn-outline btn-lg">{secondary.label}</a>}
          </div>
        )}
      </div>
      {image && (
        <div class="lg:col-span-5">
          <div class="photo-frame aspect-[4/3]">
            <img src={image} alt={imageAlt} width="560" height="420" loading="eager" />
          </div>
        </div>
      )}
    </div>
  </div>
</section>
