---
// Latin-only Subsets - hält das Bundle klein. Body: Work Sans (humanistisch).
import '@fontsource/work-sans/latin-400.css';
import '@fontsource/work-sans/latin-500.css';
import '@fontsource/work-sans/latin-600.css';
import '@fontsource/work-sans/latin-700.css';
import '../styles/global.css';
// Display (Fraunces) ist in global.css self-hosted (font-display:optional).
import workSans400 from '@fontsource/work-sans/files/work-sans-latin-400-normal.woff2?url';
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingCTA from '../components/FloatingCTA.astro';
import CookieBanner from '../components/CookieBanner.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import { site } from '../data/site';

interface Props {
  title: string;
  description?: string;
  current?: string;
  ogImage?: string;
  noindex?: boolean;
  schema?: object | object[] | null;
  heroPreload?: { srcset: string; sizes?: string };
}
const {
  title, description = site.description, current = '',
  ogImage = '/images/og-image.jpg', noindex = false, schema = null, heroPreload,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, site.url).toString();
const ogImageUrl = new URL(ogImage, site.url).toString();
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>document.documentElement.classList.add('js');</script>
    <link rel="preload" as="font" type="font/woff2" href="/fonts/fraunces-opsz.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={workSans400} crossorigin />
    {heroPreload && <link rel="preload" as="image" type="image/webp" imagesrcset={heroPreload.srcset} imagesizes={heroPreload.sizes ?? '100vw'} fetchpriority="high" />}
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex ? <meta name="robots" content="noindex, follow" /> : <meta name="robots" content="index, follow" />}
    <meta name="theme-color" content="#241D1A" />
    <meta name="author" content={site.owner} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:image" content={ogImageUrl} />

    <SchemaOrg schema={schema} />
    <ClientRouter />
  </head>
  <body>
    <a href="#main" class="skip-link">Zum Inhalt springen</a>
    <Header current={current} />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <FloatingCTA />
    <CookieBanner />

    <script>
      // Dezentes Scroll-Reveal - läuft initial und nach jeder View Transition.
      function initReveal() {
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const els = document.querySelectorAll('.fade-in');
        if (reduce) { els.forEach((e) => e.classList.add('is-visible')); return; }
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); } });
        }, { rootMargin: '0px 0px -40px 0px', threshold: 0.05 });
        els.forEach((el) => io.observe(el));
      }
      document.addEventListener('astro:page-load', initReveal);
    </script>

    <style is:global>
      .skip-link { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }
      .skip-link:focus { position: fixed; top: 1rem; left: 1rem; width: auto; height: auto; clip: auto; padding: 0.75rem 1.25rem; background: #9C0613; color: #fff; border-radius: 999px; z-index: 100; font-weight: 600; }
    </style>
  </body>
</html>
